{
  "name": "clawblox-studio",
  "version": "1.1.0",
  "description": "AI-optimized development environment for Roblox game development",
  "main": "./out/main/index.js",
  "author": "ClawBlox",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:api": "tsc --project tsconfig.api.json && tsc --project tsconfig.cli.json",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "package": "electron-vite build && electron-builder --win --config",
    "package:mac": "electron-vite build && electron-builder --mac --config",
    "package:linux": "electron-vite build && electron-builder --linux --config",
    "api": "npx tsx src/api/server.ts",
    "api:dev": "npx tsx watch src/api/server.ts"
  },
  "bin": {
    "clawblox": "./dist/cli/clawblox.js"
  },
  "dependencies": {
    "@babylonjs/core": "^8.54.3",
    "@babylonjs/gui": "^8.54.3",
    "@codemirror/language": "^6.11.3",
    "@codemirror/legacy-modes": "^6.5.2",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@monaco-editor/react": "^4.7.0",
    "@types/js-yaml": "^4.0.9",
    "@types/ws": "^8.18.1",
    "@types/xml2js": "^0.4.14",
    "ace-builds": "^1.43.4",
    "archiver": "^7.0.1",
    "cannon-es": "^0.20.0",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "fengari": "^0.1.5",
    "isomorphic-git": "^1.37.2",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.555.0",
    "monaco-editor": "^0.45.0",
    "react": "^19.1.1",
    "react-ace": "^14.0.1",
    "react-dom": "^19.1.1",
    "wasmoon": "^1.16.0",
    "ws": "^8.19.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^2.1.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@types/archiver": "^7.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.4.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^5.0.3",
    "autoprefixer": "^10.4.22",
    "concurrently": "^9.2.1",
    "electron": "^38.1.2",
    "electron-builder": "^25.1.8",
    "electron-vite": "^4.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.1.6"
  },
  "build": {
    "appId": "com.clawblox.studio",
    "productName": "ClawBlox Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "!node_modules/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
